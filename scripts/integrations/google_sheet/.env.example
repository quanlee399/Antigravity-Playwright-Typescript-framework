# ============================================================
# GOOGLE SHEETS INTEGRATION - Environment Variables
# ============================================================
# Copy file này thành .env và điền giá trị thực tế
#   cp .env.example .env
#
# QUAN TRỌNG: KHÔNG commit file .env vào Git!
# ============================================================

# --- Cách xác thực (chọn 1 trong 2 cách) ---
#
# CÁCH 1: Service Account (khuyến nghị cho CI/CD & automation)
# - Tải file credentials JSON từ Google Cloud Console
# - Đặt đường dẫn tuyệt đối hoặc tương đối đến file
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./service-account.json

# CÁCH 2: API Key (chỉ dùng cho Sheets public / read-only)
# - Tạo API Key tại: https://console.cloud.google.com/apis/credentials
# - Lưu ý: API Key không thể ghi data, chỉ đọc Sheets công khai
# GOOGLE_API_KEY=your-google-api-key-here

# --- Google Sheets Configuration ---

# Spreadsheet ID — Lấy từ URL của Google Sheet:
# https://docs.google.com/spreadsheets/d/<SPREADSHEET_ID>/edit
# VD: 1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms
GOOGLE_SPREADSHEET_ID=your-spreadsheet-id-here

# Sheet name mặc định (tab đầu tiên nếu bỏ trống)
GOOGLE_SHEET_NAME=Sheet1

# --- Output Configuration ---

# Thư mục lưu file output mặc định (relative từ project root)
OUTPUT_DIR=requirements/google_sheet

# Timezone để format timestamp trong report (VD: Asia/Ho_Chi_Minh)
TIMEZONE=Asia/Ho_Chi_Minh

# --- Test Results Sheet Configuration ---
# Tên sheet dùng để ghi kết quả test automation
RESULTS_SHEET_NAME=Test Results

# Header row số (row đầu tiên chứa tên cột) - default: 1
RESULTS_HEADER_ROW=1
